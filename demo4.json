// Bass rows have 32 elements (2 bars each). Split into 24 bars of 16.
var bassBars16 = [];
for (var i = 0; i < 24; i++) {
  var row = bassBars[Math.floor(i / 2)];
  var start = (i % 2) * 16;
  bassBars16.push(row.slice(start, start + 16));
}

function barsTo64(leadBarsArr, bassBarsArr, startBar, count) {
  var lead = [];
  var bass = [];
  for (var i = 0; i < count; i++) {
    var lb = leadBarsArr[startBar + i];
    var bb = bassBarsArr[startBar + i];
    for (var j = 0; j < 16; j++) {
      lead.push(lb ? lb[j] : '');
      bass.push(bb ? bb[j] : '');
    }
  }
  return { lead: lead, bass: bass };
}

var patterns = [];
for (var p = 0; p < 6; p++) {
  var seg = barsTo64(leadBars, bassBars16, p * 4, 4);
  patterns.push({
    length: 64,
    bass: seg.bass,
    lead: seg.lead
  });
}

var out = {
  tempo: 72,
  songArrangement: [1, 2, 3, 4, 5, 6],
  trackVolumes: [0.85, 1, 0.5, 0.5, 0.3, 0.5],
  drumVolumes: [0, 0, 0, 0],
  patterns: patterns
};

var fs = require('fs');
fs.writeFileSync('demo4.json', JSON.stringify(out, null, 2), 'utf8');
